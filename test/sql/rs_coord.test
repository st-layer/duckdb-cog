# name: test/sql/rs_coord.test
# description: RS_WorldToRasterCoord / RS_RasterToWorldCoord — 1-based 좌표 변환 (RFC §6.8 Phase 2)
# group: [cog]

require cog

require-env COG_TEST_FIXTURES

# 반환 타입: 1-based 그리드 STRUCT / 월드 STRUCT
query TT
SELECT typeof(RS_WorldToRasterCoord(f, 300005.0, 3999995.0)), typeof(RS_RasterToWorldCoord(f, 1, 1)) FROM (SELECT '${COG_TEST_FIXTURES}/basic_512x512_u16.tif' AS f);
----
STRUCT(col INTEGER, "row" INTEGER)	STRUCT(x DOUBLE, y DOUBLE)

# world → raster (1-based): 원점 코너 = (1,1), 픽셀 중심도 동일, 257번째 픽셀
query IIII
SELECT w1.col, w1.row, w2.col, w2.row FROM (
  SELECT RS_WorldToRasterCoord(f, 300000.0, 4000000.0) AS w1,
         RS_WorldToRasterCoord(f, 302565.0, 3997435.0) AS w2
  FROM (SELECT '${COG_TEST_FIXTURES}/basic_512x512_u16.tif' AS f));
----
1	1	257	257

# 순수 변환 — extent 밖도 그리드 좌표로 환산 (경계 검사 없음, Sedona 준거)
query II
SELECT w.col, w.row FROM (SELECT RS_WorldToRasterCoord('${COG_TEST_FIXTURES}/basic_512x512_u16.tif', 299995.0, 4000005.0) AS w);
----
0	0

# raster → world: 1-based 픽셀의 좌상단 코너
query IIII
SELECT r1.x::BIGINT, r1.y::BIGINT, r2.x::BIGINT, r2.y::BIGINT FROM (
  SELECT RS_RasterToWorldCoord(f, 1, 1) AS r1,
         RS_RasterToWorldCoord(f, 512, 512) AS r2
  FROM (SELECT '${COG_TEST_FIXTURES}/basic_512x512_u16.tif' AS f));
----
300000	4000000	305110	3994890

# 왕복 항등: RasterToWorld 의 코너를 WorldToRaster 에 넣으면 같은 픽셀
query II
SELECT w.col, w.row FROM (
  SELECT RS_WorldToRasterCoord(f, r.x, r.y) AS w FROM (
    SELECT RS_RasterToWorldCoord(f2.f, 300, 200) AS r, f2.f FROM (SELECT '${COG_TEST_FIXTURES}/basic_512x512_u16.tif' AS f) f2) t(r, f));
----
300	200

# NULL 인자 → NULL
query TT
SELECT RS_WorldToRasterCoord(NULL::VARCHAR, 0.0, 0.0) IS NULL, RS_RasterToWorldCoord('${COG_TEST_FIXTURES}/basic_512x512_u16.tif', NULL::INTEGER, 1) IS NULL;
----
true	true
