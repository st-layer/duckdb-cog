# name: test/sql/read_stac.test
# description: read_stac(url) — STAC Item/ItemCollection 을 (item, asset) 행으로 (RFC §6.7)
# group: [cog]

statement error
SELECT * FROM read_stac('x.json');
----
Catalog Error

require cog

require-env COG_TEST_FIXTURES

# 스키마: (item, asset) 행 — bbox 는 read_cog 와 동일 STRUCT 관례
query TT
SELECT column_name, column_type FROM (DESCRIBE SELECT * FROM read_stac('test/data/stac/items.json'));
----
item_id	VARCHAR
collection	VARCHAR
datetime	VARCHAR
asset_key	VARCHAR
href	VARCHAR
media_type	VARCHAR
bbox	STRUCT(xmin DOUBLE, ymin DOUBLE, xmax DOUBLE, ymax DOUBLE)
band_stats	STRUCT(min DOUBLE, max DOUBLE, mean DOUBLE, stddev DOUBLE)[]

# ItemCollection: 2 item × asset = 3행, graceful degradation (scene-b 결측 → NULL)
query TTTTTT
SELECT item_id, collection, datetime, asset_key, href, media_type FROM read_stac('test/data/stac/items.json') ORDER BY item_id, asset_key;
----
scene-a	demo	2026-01-15T02:30:00Z	data	basic_512x512_u16.tif	image/tiff; application=geotiff; profile=cloud-optimized
scene-a	demo	2026-01-15T02:30:00Z	thumbnail	thumb.png	image/png
scene-b	NULL	NULL	data	multiband_64x64_u8.tif	NULL

# bbox: scene-a 값, scene-b NULL
query IIT
SELECT bbox.xmin::BIGINT, bbox.ymax::BIGINT, (bbox IS NULL)::VARCHAR FROM read_stac('test/data/stac/items.json') WHERE item_id = 'scene-a' AND asset_key = 'data';
----
300000	4000000	false

query T
SELECT bbox IS NULL FROM read_stac('test/data/stac/items.json') WHERE item_id = 'scene-b';
----
true

# 단일 Item 문서도 허용
query TT
SELECT item_id, asset_key FROM read_stac('test/data/stac/single_item.json');
----
solo	cog

# 실전 조인: STAC href → RS_Width (카탈로그에서 바로 메타 접근)
query I
SELECT RS_Width('${COG_TEST_FIXTURES}/' || href) FROM read_stac('test/data/stac/items.json') WHERE item_id = 'scene-b';
----
64

# 잘못된 JSON → 경로 포함 에러
statement error
SELECT * FROM read_stac('test/data/stac/invalid.json');
----
invalid.json

# 없는 파일 → 에러
statement error
SELECT * FROM read_stac('test/data/stac/no_such.json');
----
no_such.json

# ---- raster:bands 통계 매핑 (§6.7): decode 없는 집계 재료 ----
query TIRR
SELECT asset_key, len(band_stats), band_stats[1].min, band_stats[1].stddev
FROM read_stac('test/data/stac/with_stats.json') WHERE band_stats IS NOT NULL ORDER BY asset_key;
----
red	1	1.0	18918.9
rgb	3	0.0	NULL

# 부분 결측 graceful: rgb 밴드2 stddev 있음, 밴드3 전부 NULL
query RRT
SELECT band_stats[2].stddev, band_stats[3].mean, (band_stats[3].min IS NULL)::VARCHAR
FROM read_stac('test/data/stac/with_stats.json') WHERE asset_key = 'rgb';
----
73.2	NULL	true

# 확장 없는 asset·기존 카탈로그 → band_stats NULL
query TT
SELECT (band_stats IS NULL)::VARCHAR, asset_key FROM read_stac('test/data/stac/with_stats.json') WHERE asset_key = 'nostats';
----
true	nostats

query I
SELECT count(*) FROM read_stac('test/data/stac/items.json') WHERE band_stats IS NOT NULL;
----
0

# decode 없는 집계: 카탈로그 통계만으로 자산 스캔
query RR
SELECT max(band_stats[1].max), avg(band_stats[1].mean)
FROM read_stac('test/data/stac/with_stats.json') WHERE band_stats IS NOT NULL;
----
65535.0
16447.8
